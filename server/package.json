{
  "name": "atiende-server",
  "version": "1.0.0",
  "description": "ATIENDE - Backend API",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "test": "docker-compose exec server sh -c \"NODE_ENV=test DATABASE_URL=postgresql://atiende:atiende_secret@postgres:5432/atiende_test npx jest --runInBand --forceExit\""
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": null,
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ],
    "verbose": true,
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "testRegex": "(/tests/.*\\.test\\.js)$"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.11.5",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "ioredis-mock": "^8.13.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.3",
    "supertest": "^7.2.2"
  }
}